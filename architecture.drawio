        <mxCell id="A3_mpc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;verticalAlign=middle;spacingLeft=8;" value="&lt;b&gt;MPC Solver (CVXPY / SCS)&lt;/b&gt;&lt;br/&gt;Queue: q_{t+1} &gt;= q_t + d_t - mu*g_t&lt;br/&gt;Service: s = mu * g,   g_max = 0.75&lt;br/&gt;Complexity: O(H^3) per step" vertex="1">
          <mxGeometry height="95" width="335" x="848" y="478" as="geometry" />
        </mxCell>
        <mxCell id="A3_carbon" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;verticalAlign=middle;spacingLeft=8;" value="&lt;b&gt;Carbon Budget Monitor&lt;/b&gt;&lt;br/&gt;Idle: E_idle = eta * q&lt;br/&gt;Throughput: E_tp = rho * mu * g&lt;br/&gt;Budget B = 15,  escalates gamma by 10%" vertex="1">
          <mxGeometry height="95" width="335" x="848" y="588" as="geometry" />
        </mxCell>
