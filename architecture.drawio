        <mxCell id="A2_mpc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;verticalAlign=middle;spacingLeft=8;" value="&lt;b&gt;MPC Solver (CVXPY / SCS)&lt;/b&gt;&lt;br/&gt;QP form: min x&#39;Px + c&#39;x&lt;br/&gt;alpha = 1.0,  beta = 0.5&lt;br/&gt;Strictly convex (Hessian pos. def.)" vertex="1">
