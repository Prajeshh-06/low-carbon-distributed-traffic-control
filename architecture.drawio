        <mxCell id="A3_lstm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;verticalAlign=middle;spacingLeft=8;" value="&lt;b&gt;LSTM Forecaster&lt;/b&gt;&lt;br/&gt;Forget / Input / Output gates&lt;br/&gt;Cell state update: c_t = f*c_{t-1} + i*c~&lt;br/&gt;n_h = 16,  lr = 0.005" vertex="1">
          <mxGeometry height="95" width="335" x="848" y="368" as="geometry" />
